rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── App config / Updates ───────────────────────────────────────────────
    // Allows any user (even unauthenticated) to check for app updates.
    match /app_config/{document} {
      allow read: if true;
      allow write: if false; // Only manageable via Firebase console
    }

    // ─── User profiles ──────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read profiles (for name/email search & group invite)
      allow read: if request.auth != null;

      // Only the owner can write their own profile document
      allow write: if request.auth != null && request.auth.uid == userId;

      // ── Groups ───────────────────────────────────────────────────────────
      // Any member of the group can push it to another member's subcollection.
      // Only the owner can delete from their own subcollection.
      // Group creator can also delete the group from other members' subcollections.
      match /groups/{groupId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
            && request.resource.data.keys().hasAll(['memberUids'])
            && request.auth.uid in request.resource.data.memberUids;
        allow delete: if request.auth != null
            && (request.auth.uid == userId
                || resource.data.createdBy == request.auth.uid);
      }

      // ── Transactions ─────────────────────────────────────────────────────
      // Owner can always write their own transactions.
      // Any authenticated user can push a group transaction (groupId != '')
      // to another member's subcollection so split expenses appear for everyone.
      // Creator of the transaction or Group Owner can also delete it from other members' subcollections.
      match /transactions/{txId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
            && (request.auth.uid == userId
                || (request.resource.data.keys().hasAll(['groupId'])
                    && request.resource.data.groupId is string
                    && request.resource.data.groupId != ''));
        allow delete: if request.auth != null
            && (request.auth.uid == userId
                || resource.data.createdBy == request.auth.uid
                || (resource.data.keys().hasAll(['groupId'])
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid)/groups/$(resource.data.groupId))
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)/groups/$(resource.data.groupId)).data.createdBy == request.auth.uid));
      }

      // ── All other subcollections (budgets, goals, bills, subscriptions…) ─
      match /{subCollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
